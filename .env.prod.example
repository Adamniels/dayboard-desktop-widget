# Production env for the Mac mini. Copy to .env.prod (gitignored) and fill in, then:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
#
# .env.prod holds the Google client secret and host-specific URLs — keep it out of git.

# --- Frontend URLs (COMPILE-TIME: baked into the display/admin bundles at build) ---
# Use the Mini's Tailscale MagicDNS name or tailnet IP (NOT localhost) so the admin on
# your laptop can reach the api across the tailnet. The kiosk on the Mini reaches the same
# tailnet host fine. If you change either value, rebuild: `... up -d --build display admin`.
VITE_API_URL=http://YOUR-MINI.tailXXXX.ts.net:3000
VITE_DISPLAY_URL=http://YOUR-MINI.tailXXXX.ts.net:4173

# --- Host ports published on the Mini (must not collide; habitquest uses 3001) ---
API_HOST_PORT=3000
DISPLAY_HOST_PORT=4173
ADMIN_HOST_PORT=4174

# --- Display timezone (IANA name) — pins the wall clock/grid deterministically ---
DISPLAY_TZ=Europe/Stockholm

# --- Postgres (kept as demo per your choice; DB is not published off the Mini) ---
POSTGRES_PASSWORD=dayboard

# --- Google Calendar sync ---
SYNC_INTERVAL_MS=45000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Loopback redirect for the one-off google:connect flow. Must match your Google client.
GOOGLE_REDIRECT_URI=http://127.0.0.1:53682/oauth2callback
