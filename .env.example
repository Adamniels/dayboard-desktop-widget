# Copy to .env and adjust. .env is gitignored; .env.example is committed.

# Postgres connection used by apps/api (Drizzle) and drizzle-kit.
DATABASE_URL=postgres://dayboard:dayboard@localhost:5432/dayboard

# Port the api listens on (REST + WebSocket).
API_PORT=3000

# Base URL the frontends use to reach the api. On the Mini this is the
# Tailscale hostname; localhost is for local development.
VITE_API_URL=http://localhost:3000
