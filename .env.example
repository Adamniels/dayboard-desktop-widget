# Copy to .env and adjust. .env is gitignored; .env.example is committed.

# Postgres connection used by apps/api (Drizzle) and drizzle-kit.
DATABASE_URL=postgres://dayboard:dayboard@localhost:5432/dayboard

# Port the api listens on (REST + WebSocket).
API_PORT=3000

# Base URL the frontends use to reach the api. On the Mini this is the
# Tailscale hostname; localhost is for local development.
VITE_API_URL=http://localhost:3000

# Timezone the display positions events in. Leave unset to use the Mini's system
# timezone. Set explicitly (an IANA name) to make the wall display deterministic.
# DISPLAY_TZ=America/Denver
# DISPLAY_START_HOUR=7
# DISPLAY_END_HOUR=21

# Google sync poll interval in milliseconds (default 45000).
# SYNC_INTERVAL_MS=45000

# Google OAuth client (create an OAuth 2.0 Client ID of type "Desktop app" or "Web"
# in Google Cloud Console). Needed for `pnpm --filter @dayboard/api google:connect`
# and the sync engine. The redirect must match the client config.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:53682/oauth2callback
